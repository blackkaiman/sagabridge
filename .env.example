# =====================================================
# .env.example - copiati ca .env si ajustati valorile
# =====================================================

# ---------- AI local (Ollama + Tesseract) ----------
# Server-ul Ollama ruleaza local pe portul 11434 (default).
# Porneste-l in alt terminal cu: `ollama serve`
OLLAMA_HOST=http://localhost:11434

# Modelul Ollama folosit pentru structurare. Pull-uieste cu:
#   ollama pull llama3.2:3b
# Alternative: qwen2.5:3b (mai bun la JSON), llama3.1:8b (mai precis, mai lent)
OLLAMA_MODEL=llama3.2:3b

# Limbile Tesseract pentru OCR. Necesita pachetele: `brew install tesseract-lang`
TESSERACT_LANG=ron+eng

# Limite procesare PDF
MAX_PAGES=3
MIN_TEXT_LENGTH=200

# ---------- Verificare firma ----------
ENABLE_COMPANY_VERIFICATION=true
# Provider activ: anaf | vies | openapi | listafirme
# - "anaf"  e gratuit, public, ideal pentru firme romanesti
# - "vies"  validare VAT UE (Comisia Europeana), gratuit
# - "openapi" / "listafirme" - servicii comerciale (necesita cheie)
COMPANY_API_PROVIDER=anaf
COMPANY_API_KEY=
COMPANY_API_BASE_URL=
ANAF_API_TOKEN=

# ---------- Cautare mentiuni online ----------
ENABLE_ONLINE_MENTIONS=true
# Provider: "duckduckgo" (gratuit, fara cheie, default).
SEARCH_PROVIDER=duckduckgo
MAX_ONLINE_MENTIONS=5
